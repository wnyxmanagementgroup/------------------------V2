rules_version = '2';

// ===================================================================
// Firebase Storage Security Rules — ระบบไปราชการ WNY HQ
// ===================================================================

service firebase.storage {
  match /b/{bucket}/o {

    // memos/{username}/{filename}
    // อนุญาตให้ผู้ใช้ที่ login แล้ว (รวม anonymous) อ่าน/เขียนได้
    match /memos/{username}/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024  // ไม่เกิน 20 MB
                   && request.resource.contentType.matches('application/pdf');
    }

    // ปิดกั้นทุก path ที่ไม่ได้ระบุ
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
